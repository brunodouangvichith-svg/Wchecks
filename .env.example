# Copier ce fichier en ".env" et renseigner les valeurs reelles.
# Ne jamais committer le fichier ".env" (voir .gitignore).

# Neon (PostgreSQL serverless) - projet gratuit : https://neon.tech
# Chaîne de connexion trouvée dans le dashboard Neon > Connection Details
# (utiliser l'URL avec pooler, recommandée pour un usage serverless).
DATABASE_URL=

# EIA - clé gratuite : https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# AISstream.io - clé gratuite : https://aisstream.io
AISSTREAM_API_KEY=

# Google AI Studio - agent "Joe" (clients/joe_agent.py) : https://aistudio.google.com/apikey
# Tier gratuit disponible mais PAS illimité (contrairement aux autres sources du projet) -
# voir config.JOE_MAX_ARTICLES_PER_RUN pour le plafond de cout.
GEMINI_API_KEY=
